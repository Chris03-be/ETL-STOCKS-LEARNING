# ============================================================
# DATABASE CONFIGURATION - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=your_secure_password_here
DB_DATABASE=etl_stocks
DB_SCHEMA=public

# ============================================================
# DLT CONFIGURATION
# ============================================================
DLT_PIPELINE_NAME=undervalued_stocks
DLT_PROJECT_NAME=etl_stocks
DLT_DATASET_NAME=bronze

# ============================================================
# DBT CONFIGURATION
# ============================================================
DBT_PROFILES_DIR=~/.dbt
DBT_PROJECT_DIR=src/transformation/dbt_project
DBT_TARGET=dev
DBT_THREADS=4

# ============================================================
# APIS CONFIGURATION
# ============================================================

# Yahoo Finance (Free, no key needed)
YAHOO_FINANCE_ENABLED=true
YAHOO_FINANCE_TIMEOUT=30

# Alpha Vantage (Free tier: 5 calls/min, 500/day)
ALPHA_VANTAGE_ENABLED=true
ALPHA_VANTAGE_API_KEY=your_key_here
ALPHA_VANTAGE_TIMEOUT=30

# IEX Cloud (Optional, for premium fundamentals)
IEX_CLOUD_ENABLED=false
IEX_CLOUD_API_KEY=your_key_here

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_DIRECTORY=data/logs
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================
# PIPELINE CONFIGURATION
# ============================================================
PIPELINE_MODE=production
PIPELINE_SCHEDULE_TIME=16:00  # Daily 4 PM UTC (after market close)
PIPELINE_TIMEZONE=UTC
PIPELINE_ERROR_RETRIES=3
PIPELINE_RETRY_DELAY=5

# ============================================================
# DATA CONFIGURATION
# ============================================================
HISTORICAL_DAYS=365
TICKERS=INTC,CI,F,ADBE,MO,SIE,NESTE,CMCSA,GDMK,601318.SS

# ============================================================
# ORCHESTRATION CONFIGURATION
# ============================================================
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_LOG_FILE=data/logs/scheduler.log

# ============================================================
# NOTIFICATION CONFIGURATION (Optional)
# ============================================================
NOTIFICATION_ENABLED=false
NOTIFICATION_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============================================================
# POWER BI CONFIGURATION (Optional)
# ============================================================
POWER_BI_REFRESH_ENABLED=false
POWER_BI_WORKSPACE_ID=your_workspace_id
POWER_BI_DATASET_ID=your_dataset_id
POWER_BI_CLIENT_ID=your_client_id
POWER_BI_CLIENT_SECRET=your_client_secret
POWER_BI_TENANT_ID=your_tenant_id

# ============================================================
# ENVIRONMENT
# ============================================================
ENVIRONMENT=production
DEBUG=false