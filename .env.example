# ============================================================
# DATABASE CONFIGURATION - PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=etl_user
DB_PASSWORD=your_secure_password_here
DB_DATABASE=etl_stocks
DB_SCHEMA=public

# ============================================================
# DLT CONFIGURATION
# ============================================================
DLT_PIPELINE_NAME=undervalued_stocks
DLT_PROJECT_NAME=etl_stocks
DLT_DATASET_NAME=bronze

# ============================================================
# DBT CONFIGURATION
# ============================================================
DBT_PROFILES_DIR=~/.dbt
DBT_PROJECT_DIR=src/transformation/dbt_project
DBT_TARGET=dev
DBT_THREADS=4

# ============================================================
# INGESTION CONFIGURATION
# ============================================================
TICKERS=INTC,CI,F,ADBE,OR.PA,SIE.DE
HISTORICAL_DAYS=365
MAX_RETRIES=3

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_DIRECTORY=data/logs
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================
# ORCHESTRATION CONFIGURATION
# ============================================================
PIPELINE_SCHEDULE_TIME=22:00
PIPELINE_TIMEZONE=UTC

# ============================================================
# ML CONFIGURATION
# ============================================================
ML_MODEL_DIR=models
ML_TEST_SIZE=0.2
ML_RANDOM_STATE=42

# ============================================================
# ENVIRONMENT
# ============================================================
ENVIRONMENT=production
DEBUG=false